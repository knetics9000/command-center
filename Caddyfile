# Caddy auto-HTTPS for Command Center. CC_DOMAIN comes from .env.
# After the site is confirmed working, lock it with a password by uncommenting
# basic_auth below (generate the hash with:
#   docker run --rm caddy:2 caddy hash-password --plaintext 'YOUR_PASSWORD'
# then paste it after the username).

{$CC_DOMAIN} {
	# The Android notification app posts to /api/notify. It can't pass the
	# password wall, so this one path skips basic_auth — it's protected by the
	# NOTIFY_TOKEN bearer token instead (checked in the route handler).
	@notify path /api/notify
	handle @notify {
		reverse_proxy app:3000
	}

	# Everything else (the UI + all other APIs) sits behind the password.
	handle {
		# basic_auth {
		# 	kurt PASTE_BCRYPT_HASH_HERE
		# }
		reverse_proxy app:3000
	}
}
