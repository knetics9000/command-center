# Copy to .env on the VPS (in the project folder) and fill in. NEVER commit the real .env.
# docker compose reads this file automatically for both ${VAR} substitution and container env.

# --- Domain (Caddy serves HTTPS here; point its DNS A-record at the VPS) ---
CC_DOMAIN=command.yourdomain.com

# --- App secrets ---
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_MODEL_SMART=claude-sonnet-4-6

GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# Must also be added in Google Cloud Console > Credentials (matches CC_DOMAIN):
GOOGLE_REDIRECT_URI=https://command.yourdomain.com/api/google/callback

OFFLOAD_URL=https://script.google.com/macros/s/.../exec
OFFLOAD_TOKEN=...
OFFLOAD_SHEET_ID=...

# --- Phone notification capture (Android NotificationListener app) ---
# Long random string; paste the SAME value into the Android app's settings.
# Generate one with: openssl rand -hex 32
NOTIFY_TOKEN=...

# Inside the container the DB lives on the mounted volume:
DATABASE_PATH=/app/data/command-center.db

# --- Co-parent kids inbox ---
ACCOUNT_COPARENT=kmriedel0214@gmail.com
# Bucket names for the Kids widget (first names become the buckets):
KIDS_NAMES=Kurt Riedel, Nova Riedel, Jayden Harvey
