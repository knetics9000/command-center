# ---- Command Center App config (copy to .env, fill in, never commit .env) ----

# Claude API (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_FAST=claude-haiku-4-5
CLAUDE_MODEL_SMART=claude-sonnet-4-6

# Google OAuth (one app, both accounts authorize through it)
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=...
# Must exactly match an Authorized redirect URI in the Google Cloud OAuth client:
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Accounts (labels only; tokens are stored in SQLite after OAuth)
ACCOUNT_PERSONAL=kingkurt1978@gmail.com
ACCOUNT_WORK=kurt@cybertechs24.com
# Calendar that auto-created events land on (the personal account's primary):
CALENDAR_ACCOUNT=kingkurt1978@gmail.com

# Offload Apps Script (same endpoint the artifact uses)
OFFLOAD_URL=https://script.google.com/macros/s/.../exec
OFFLOAD_TOKEN=...
OFFLOAD_SHEET_ID=1Kzsi0xB7rgBz8O1kWnCIi3Dz8H1LAQ-8GeMkFkQaNYM

# App
APP_BASE_URL=http://localhost:3000
DATABASE_PATH=./data/command-center.db
